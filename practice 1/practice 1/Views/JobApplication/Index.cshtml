@model practice_1.Models.JobApplication

@{
    ViewData["Title"] = "Job Application";
}

<h2>Job Application Form</h2>

<div class="text-danger">
    @Html.ValidationSummary()
</div>

<form method="post">

    <div class="mb-3">
        <label class="form-label">Applicant Name</label>
        <input type="text" class="form-control" name ="ApplicantName" value="@Model?.ApplicantName"/>
        <span class="text-danger">@Html.ValidationMessage("ApplicantName")</span>
    </div>

    <div class="mb-3">
        <label class="form-label">Email</label>
        <input type = "email" class="form-control" name="Email" value="@Model?.Email"/>
        <span class="text-danger">@Html.ValidationMessage("Email")</span>
    </div>
    
    <div class="mb-3">
        <label class="form-label">Position Applied For</label>
        <input type="text" class="form-control" name="PositonAppliedFor" value="@Model?.PositonAppliedFor" />
        <span class="text-danger"> @Html.ValidationMessage("PositonAppliedFor") </span>
    </div>
    
    <div class="mb-3">
    <label class="form-label">Years of Experience</label>
    <input type="number" class="form-control" name="YearOfExperience" value="@Model?.YearOfExperience" />
    <span class="text-danger"> @Html.ValidationMessage("YearOfExperience") </span>
    </div>
    
    <div class="mb-3">
        <label class="form-label">Expected Salary</label>
        <input type="number" class="form-control" name="ExpectedSalary" value="@Model?.ExpectedSalary" />
        <span class="text-danger"> @Html.ValidationMessage("ExpectedSalary") </span>
    </div>
    
    <button type ="submit"  class="btn btn-primary">Submit</button>
</form>

@if (Model != null && ViewData.ModelState.IsValid)
{
    

    <h3>Applicant Details</h3>

    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Applicant Name</th>
                <th>Position</th>
                <th>Expected Salary</th>
            </tr>
        </thead>

        <tbody>
            <tr>
                <td>@Model.ApplicantName</td>
                <td>@Model.PositonAppliedFor</td>
                <td>@Model.ExpectedSalary</td>
            </tr>
        </tbody>
    </table>
}