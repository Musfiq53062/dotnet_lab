@model _530623.Models.Course
@{
    ViewData["Title"] = "Course Information";
}
<h2>Course Information Form Validation </h2>
<form asp-action="Create" method ="post">
    <div>
        <label asp-for ="CourseId" class ="form-label" > Course ID</label>
        <input asp-for = "CourseId" type ="number" class="form-control"/>
        <span asp-validation-for ="CourseId" class="text-danger"></span>
    </div>
    <div>
        <label asp-for="CourseName" class="form-label"> Course Name</label>
        <input asp-for="CourseName" type="text" class="form-control" />
        <span asp-validation-for="CourseName" class="text-danger"></span>
    </div>
    <div>
        <label asp-for="Credit" class="form-label"> </label>
        <input asp-for="Credit" type="number" class="form-control" />
        <span asp-validation-for="Credit" class="text-danger"></span>
    </div>
    <div>
        <label asp-for="CourseFee" class="form-label"> Course Fee</label>
        <input asp-for="CourseName" type="number" class="form-control" />
        <span asp-validation-for="CourseName" class="text-danger"></span>
    </div>
    <div>
        <label asp-for="CourseCode" class="form-label"> Course Code</label>
        <input asp-for="CourseCode" type="number" class="form-control" />
        <span asp-validation-for="CourseCode" class="text-danger"></span>
    </div>
    
    <button type="submit">Submit </button>


</form>
